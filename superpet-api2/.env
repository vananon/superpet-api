# Puerto donde escucha la API DENTRO de su contenedor
PORT=3000

# ===== CASO A: TODO EN DOCKER-COMPOSE (recomendado) =====
# La API se conecta a Mongo por el NOMBRE del servicio y su puerto INTERNO (27017)
MONGO_HOST=mongo
MONGO_PORT=27017

# ===== CASO B: probar la API en tu PC (sin Docker) contra el Mongo del contenedor =====
# Descomenta estas dos y comenta las de arriba:
# MONGO_HOST=localhost
# MONGO_PORT=3000

MONGO_DB=Superpet
MONGO_USER=superpet_admin
MONGO_PASS=SuperpetVM123!
MONGO_AUTH_SOURCE=admin
